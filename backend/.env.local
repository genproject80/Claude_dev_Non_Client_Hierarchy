# Local Development Environment Variables
# Copy this to .env for local development, but never commit .env to git

# Database Configuration
DB_SERVER=genvolt.database.windows.net
DB_DATABASE=gendb
DB_USERNAME=genadmin
DB_PASSWORD=genvolt@123
DB_DRIVER=ODBC Driver 17 for SQL Server

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-for-local-dev-only
JWT_EXPIRES_IN=24h

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration
FRONTEND_URL=http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=1000