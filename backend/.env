# Production Environment Variables Template
# These values are overridden by Azure App Service settings in production
# For local development, copy .env.local to .env

# Database Configuration - Set in Azure App Service
DB_SERVER=${DB_SERVER}
DB_DATABASE=${DB_DATABASE}
DB_USERNAME=${DB_USERNAME}
DB_PASSWORD=${DB_PASSWORD}
DB_DRIVER=ODBC Driver 17 for SQL Server

# JWT Configuration - Set in Azure App Service  
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRES_IN=24h

# Server Configuration
PORT=3001
NODE_ENV=${NODE_ENV}

# CORS Configuration - Set in Azure App Service
FRONTEND_URL=${FRONTEND_URL}

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=1000